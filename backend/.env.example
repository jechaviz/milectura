# Mi Lectura Diaria — backend config (copy to .env for local dev).
# All optional; sensible defaults are baked in.

# HTTP port for the standalone/dev server (ignored in CGI mode).
ML_PORT=8091

# Directory holding the MyBible (ph4.org) *.SQLite3 modules.
# Defaults to <repo>/modules. On Spaceship the shim sets this to a path
# OUTSIDE the docroot (see backend/deploy/shim.php: ML_MODULES).
# ML_MODULES=C:\git\websites\milectura\modules

# Base path when hosted under a sub-path (Spaceship: /milectura). The binary
# strips this from the request path itself. The shim sets ML_BASE_PATH=/milectura.
# ML_BASE_PATH=/milectura

# CORS origin for cross-origin API calls (same-origin SPA needs none).
# ML_CORS_ORIGIN=https://appniverse.com
